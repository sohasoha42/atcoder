{
        "version": "2.0.0",
        "tasks": [
                {
                        "label": "build-cpp",
                        "type": "cppbuild",
                        "command": "/opt/homebrew/bin/g++",
                        "args": [
                                "-g",
                                "${file}",
                                "-o",
                                "${fileDirname}/${fileBasenameNoExtension}"
                        ],
                        "options": {
                                "cwd": "${workspaceFolder}"
                        },
                        "group": {
                                "kind": "build",
                                "isDefault": true
                        },
                        "problemMatcher": [
                                "$gcc"
                        ],
                        "detail": "Compile active C++ file with g++"
                }
        ]
}